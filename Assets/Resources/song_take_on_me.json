    "lyrics": [
    { "time": 33.10, "text": "Talking away" },
    { "time": 36.95, "text": "I don’t know what I'm to say" },
    { "time": 40.08, "text": "I’ll say it anyway" },
    { "time": 41.63, "text": "Today is another day to find you" },
    { "time": 45.82, "text": "Shying away" },
    { "time": 47.73, "text": "I’ll be coming for your love, okay?" },

    { "time": 50.41, "text": "Take on me (take on me)" },
    { "time": 56.70, "text": "Take me on (take on me)" },
    { "time": 62.09, "text": "I’ll be gone" },
    { "time": 66.93, "text": "In a day or two" },

    { "time": 72.87, "text": "So needless to say" },
    { "time": 75.71, "text": "I’m odds and ends, but I’m me" },
    { "time": 78.20, "text": "Stumbling away" },
    { "time": 81.39, "text": "Slowly learning that life is okay" },
    { "time": 84.59, "text": "Say after me" },
    { "time": 88.49, "text": "It's no better to be safe than sorry" },

    { "time": 91.17, "text": "Take on me (take on me)" },
    { "time": 96.01, "text": "Take me on (take on me)" },
    { "time": 101.85, "text": "I’ll be gone" },
    { "time": 106.69, "text": "In a day or two" },

    { "time": 151.40, "text": "All the things that you say, yeah" },
    { "time": 155.84, "text": "Is it life, or just to play my worries away?" },
    { "time": 160.72, "text": "You're all the things I’ve got to remember" },
    { "time": 164.92, "text": "You're shying away" },
    { "time": 166.51, "text": "I’ll be coming for you anyway" },

